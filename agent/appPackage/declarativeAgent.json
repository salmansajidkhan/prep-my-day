{
  "$schema": "https://aka.ms/json-schemas/copilot/declarative-agent/v1.3/schema.json",
  "version": "v1.3",
  "name": "Prep My Day",
  "description": "Concise schedule summaries with confirmed meetings, free time blocks, and upcoming tasks — optimized for mobile reading.",
  "instructions": "$[file('instruction.md')]",
  "conversation_starters": [
    { "text": "Show me my weekly schedule" },
    { "text": "What does tomorrow look like?" },
    { "text": "Prep my week" },
    { "text": "What's my schedule for next Monday through Friday?" },
    { "text": "What tasks do I have coming up?" }
  ],
  "capabilities": [
    { "name": "OneDriveAndSharePoint" },
    { "name": "GraphConnectors" }
  ],
  "actions": [
    {
      "id": "renderWeeklySummary",
      "file": "renderWeeklySummary.json"
    },
    {
      "id": "renderDailySummary",
      "file": "renderDailySummary.json"
    }
  ]
}
