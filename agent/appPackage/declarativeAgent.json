{
  "$schema": "https://aka.ms/json-schemas/copilot/declarative-agent/v1.4/schema.json",
  "version": "v1.4",
  "name": "Prep My Day",
  "description": "Comprehensive morning briefings with schedule, email digest, Teams highlights, meeting prep, and tasks — optimized for mobile reading.",
  "instructions": "$[file('instruction.md')]",
  "capabilities": [
    { "name": "Email" },
    { "name": "TeamsMessages" },
    { "name": "People" }
  ],
  "conversation_starters": [
    { "text": "Prep my day" },
    { "text": "Morning brief" },
    { "text": "Show me my weekly schedule" },
    { "text": "What does tomorrow look like?" },
    { "text": "What emails need my attention?" },
    { "text": "Prep me for my next meeting" }
  ],
  "actions": [
    {
      "id": "renderWeeklySummary",
      "file": "renderWeeklySummary.json"
    },
    {
      "id": "renderDailySummary",
      "file": "renderDailySummary.json"
    },
    {
      "id": "renderMorningBrief",
      "file": "renderMorningBrief.json"
    }
  ]
}
