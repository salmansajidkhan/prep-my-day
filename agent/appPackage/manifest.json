{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/vDevPreview/MicrosoftTeams.schema.json",
  "manifestVersion": "devPreview",
  "id": "{{APP_ID}}",
  "version": "1.0.0",
  "developer": {
    "name": "Salman Khan",
    "websiteUrl": "https://github.com/ArmGameDev",
    "privacyUrl": "https://privacy.microsoft.com",
    "termsOfUseUrl": "https://www.microsoft.com/servicesagreement"
  },
  "name": {
    "short": "Prep My Day",
    "full": "Prep My Day — Proactive Schedule & Task Summaries"
  },
  "description": {
    "short": "Proactive schedule summaries and task reminders via Teams",
    "full": "Prep My Day delivers concise weekly and daily schedule summaries with meetings, free time blocks, and upcoming tasks — optimized for mobile reading. Powered by Microsoft Graph Calendar and WorkIQ."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "prepMyDayAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [
    "localhost",
    "prep-my-day.loca.lt"
  ]
}
